<?xml version="1.0" encoding="utf-8"?>
<!-- 数据提取规则：Android 12+ 配置 -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="device.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="device.xml" />
    </device-transfer>
</data-extraction-rules>
